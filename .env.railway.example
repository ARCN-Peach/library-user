# Plantilla de variables de entorno para Railway
# Copia estas variables en Railway Dashboard → Variables

# ============================================================
# BASE DE DATOS (PostgreSQL)
# ============================================================
# Si usas PostgreSQL en Railway, obtén estos valores de:
# Railway Dashboard → PostgreSQL Service → Variables

DB_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/railway
DB_USER=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}

# Alternativa si prefieres valores explícitos:
# DB_URL=jdbc:postgresql://postgres-railway-prod.railway.internal:5432/railway
# DB_USER=postgres
# DB_PASSWORD=tu-contraseña-postgresql-generada

# ============================================================
# RABBITMQ
# ============================================================
# Si usas RabbitMQ en Railway:

RABBITMQ_HOST=${{RabbitMQ.RABBITMQ_HOST}}
RABBITMQ_PORT=${{RabbitMQ.RABBITMQ_PORT}}
RABBITMQ_USER=${{RabbitMQ.RABBITMQ_DEFAULT_USER}}
RABBITMQ_PASSWORD=${{RabbitMQ.RABBITMQ_DEFAULT_PASS}}

# Alternativa si prefieres valores explícitos:
# RABBITMQ_HOST=rabbitmq-railway-prod.railway.internal
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# ============================================================
# JWT - IMPORTANTE: Cambiar en producción
# ============================================================
# Genera con: openssl rand -base64 32
# Mínimo 30 caracteres

JWT_SECRET=change-me-in-production-with-a-long-secret-min-30-characters-abc123def456

# ============================================================
# BOOTSTRAP LIBRARIAN (Crear admin inicial)
# ============================================================
# Cambiar según tus necesidades

BOOTSTRAP_LIBRARIAN_ENABLED=true
BOOTSTRAP_LIBRARIAN_NAME=Admin Librarian
BOOTSTRAP_LIBRARIAN_EMAIL=admin@library.local
BOOTSTRAP_LIBRARIAN_PASSWORD=AdminPassword123!

# ============================================================
# NOTAS IMPORTANTES
# ============================================================
# 1. Reemplaza todos los valores placeholder
# 2. JWT_SECRET debe ser >= 30 caracteres
# 3. BOOTSTRAP_LIBRARIAN_PASSWORD debe ser fuerte
# 4. Si usas variables de Railway (con ${{}}), el sistema las resuelve automáticamente
# 5. Nunca commitees credenciales reales al repositorio
